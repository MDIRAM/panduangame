APP_NAME="panduangame"
APP_ENV=production
APP_KEY=  # Run 'php artisan key:generate' on the server to generate this
APP_DEBUG=false
APP_TIMEZONE='Asia/Jakarta'
APP_URL="https://wghcenter.site"
ASSET_URL="https://wghcenter.site"
DEBUGBAR_ENABLED=false
ASSET_PREFIX=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info  # Changed to 'info' for production to reduce log bloat

DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE="panduangame"
DB_USERNAME=root
DB_PASSWORD="your_strong_database_password_here"  # Must match MYSQL_ROOT_PASSWORD in docker-compose

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public  # Set to public for production uploads
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@wghcenter.site"
MAIL_FROM_NAME="Walkthrough Game Hub"

VITE_APP_NAME="${APP_NAME}"
